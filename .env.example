OPENAI_API_KEY=

# Browser settings
# Leave empty to show browser window (headless=False)
# Set any value (true, 1, yes, etc.) to run headless (headless=True)
HEADLESS=

# Agent models (defaults: gpt-5.4 / gpt-5.4-mini)
INVOICE_MODEL=
INVOICE_FALLBACK_MODEL=

# POST destination for failed run reports (portal failures, aborts).
# Leave empty to disable.
INVOICE_FAILURE_WEBHOOK_URL=https://webhook.site/your-webhook-id
